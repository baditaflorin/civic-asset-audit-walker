{
  "name": "civic-asset-audit-walker",
  "version": "0.3.0",
  "private": true,
  "description": "Offline-first web app for volunteers to scan tagged civic assets, report conditions, and share anonymous audits.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/prepare-pages.mjs",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/finalize-pages.mjs",
    "pages-preview": "vite preview --host 0.0.0.0 --outDir docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke": "bash scripts/smoke.sh",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "hooks:pre-commit": ".githooks/pre-commit",
    "hooks:commit-msg": ".githooks/commit-msg .git/COMMIT_EDITMSG",
    "hooks:pre-push": ".githooks/pre-push",
    "clean": "rm -rf coverage playwright-report test-results docs/assets docs/index.html docs/404.html docs/manifest.webmanifest docs/registerSW.js docs/sw.js docs/workbox-*.js"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@tanstack/react-query": "^5.100.9",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "apriltag": "^2.0.3",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22"
  }
}
